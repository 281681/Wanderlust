<% layout("/layouts/boilerplate")%>

    <body>
        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h1>Edit Your Listing</h1>

                <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="title">Title</label>
                        <input class="form-control" name="listing[title]" value="<%= listing.title%>" type="text"
                            id="title" required>
                    </div>

                    <div class="mb-3">
                        <label for="description">Description</label>
                        <textarea class="form-control" name="listing[description]"
                            id="description" required><%= listing.description%></textarea>
                            <div class="invalid-feedback">
                            Please enter a short Description
                        </div>
                    </div>

                    <!-- <div class="mb-3">
                        <label for="image">Image URL</label>
                        <input class="form-control" name="listing[image]" value="<%= listing.image%>" type="text"
                            id="image" required>
                            <div class="invalid-feedback">
                                Url should be valid
                            </div>
                    </div> -->
                    <div  class=" col-6 card mb-3">
                        Original Listing Image
                        <img src="<%= oroginalImageUrl%>" alt="listing image">

                    </div>
                     <div class="mb-3">
                        <label class="form-label" for="image">Upload Image</label>
                        <input class="form-control" name="listing[image]"  type="file"
                            id="image" />
                    </div>

                    <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price"> Price</label>
                        <input class="form-control" name="listing[price]" value="<%= listing.price%>" 
                            id="price" required>
                            <div class="invalid-feedback">
                                Price should be valid
                            </div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country">Country</label>
                        <input class="form-control" name="listing[country]" value="<%= listing.country%>" type="text"
                            id="country" required>
                            <div class="invalid-feedback">
                                Country should be valid
                            </div>
                    </div>
                    </div>

                    <div class="mb-3">
                        <label for="location">Location</label>
                        <input class="form-control" name="listing[location]" value="<%= listing.location%>" type="text"
                            id="location" required>
                            <div class="invalid-feedback">
                                Location should be valid
                            </div>
                    </div>
                    <button class="btn btn-dark mt-3 mb-3 edit-btn">Edit</button>
            </div>
        </div>
        </form>


    </body>