    <script>
      const taxSwitch = document.getElementById("switchCheckDefault");
      const taxinfo = document.getElementsByClassName("tax-info");

      function syncTaxDisplay() {
        for (let el of taxinfo) {
          el.classList.toggle("show-tax", taxSwitch.checked);
        }
      }

      //  Restore saved state
      const savedState = localStorage.getItem("showTax");
      if (savedState !== null) {
        taxSwitch.checked = savedState === "true";
      }

      //  Sync UI on load
      syncTaxDisplay();

      //  Save + sync on change
      taxSwitch.addEventListener("change", () => {
        localStorage.setItem("showTax", taxSwitch.checked);
        syncTaxDisplay();
      });
    </script>




