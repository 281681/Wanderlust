            <div class="card-img-overlay">
              <p>
              </p>
            </div>
            <div class="card-body">
              <p class="card-text">
                <b>
                  <%= listing.title %>
                </b>
                <br />
                &#8377; <%=listing.price.toLocaleString("en-IN") %> /night
                  <i class="tax-info show-tax">&nbsp; &nbsp;+18% GST</i>

              </p>
            </div>
          </div>
        </a>
