<% layout("/layouts/boilerplate")%>
        <div class="row mt-3"> 
            <div class="col-6 offset-3"><h1>Signup for Wanderlust</h1></div>
            <div class="col-6 offset-3">
                <form action="/user/signup" method="POST" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label class="form-label" for="username">username</label>
                        <input class="form-control" name="username" placeholder="Enter username" type="text"
                            id="username" required />
                            <div class="valid-feedback">
                              username look`s good
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="email">Email</label>
                        <input class="form-control" name="email" placeholder="Enter email" type="email"
                            id="email" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="password">Title</label>
                        <input class="form-control" name="password" placeholder="Enter password" type="password"
                            id="password" required />
                    </div>
                    <button class="btn btn-success">Signup</button>


                </form>
            </div>
        </div>        